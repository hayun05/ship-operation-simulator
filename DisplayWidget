#include <QWidget>
#include <QLabel>
#include <QVBoxLayout>

class DisplayWidget : public QWidget
{
    Q_OBJECT

public:
    DisplayWidget(QWidget *parent = nullptr) : QWidget(parent)
    {
        QVBoxLayout *layout = new QVBoxLayout(this);

        label = new QLabel("Current Brightness: 50%", this);
        layout->addWidget(label);

        setLayout(layout);
    }

public slots:
    void updateBrightness(int brightness)
    {
        label->setText(QString("Current Brightness: %1%").arg(brightness));
    }

private:
    QLabel *label;
};
