#include <QMainWindow>
#include <QWidget>
#include <QSplitter>
#include <QVBoxLayout>
#include <QPushButton>

#include "SettingsWidget.h"
#include "DisplayWidget.h"

class MainWindow : public QMainWindow
{
    Q_OBJECT

public:
    MainWindow(QWidget *parent = nullptr)
        : QMainWindow(parent)
    {
        // 설정 위젯과 화면 위젯 생성
        settingsWidget = new SettingsWidget(this);
        displayWidget = new DisplayWidget(this);

        // QSplitter를 수직 방향으로 변경하여 화면을 상하로 나누기
        QSplitter *splitter = new QSplitter(Qt::Vertical, this);
        
        // 화면 위젯을 왼쪽에, 설정 위젯을 오른쪽에 배치
        splitter->addWidget(displayWidget);
        splitter->addWidget(settingsWidget);

        setCentralWidget(splitter);

        // 설정이 변경될 때 화면에 반영되도록 연결
        connect(settingsWidget, &SettingsWidget::settingsChanged,
                displayWidget, &DisplayWidget::updateBrightness);

        setWindowTitle("Settings and Display Example");
        resize(800, 400);
    }

private:
    SettingsWidget *settingsWidget;
    DisplayWidget *displayWidget;
};
